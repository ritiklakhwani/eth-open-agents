# Sepolia
SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
# Pet workers: wait up to this many ms for both BattleEscrow stakes after createBattle (default 600000 = 10m)
BATTLE_ESCROW_STAKE_TIMEOUT_MS=600000
# Hub ENS + pet-runtime BattleEscrow serialize writes via data/.deployer-tx-lock under the monorepo root
# (pet workers use the same root as cwd). Avoid editing/deleting that file while the hub or workers run.

# 0G Testnet
ZERO_G_RPC_URL=
ZERO_G_INDEXER_URL=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# REPLICATE_API_TOKEN= (deprecated — sprite-gen now uses OpenAI with Pollinations fallback)

# Frontend (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_DEMO_RECIPIENT=
NEXT_PUBLIC_HUB_URL=http://localhost:3001
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# Dev-only (apps/web server): force arena matchmaking to only pair these two pet token_ids.
# Example: BATTLE_FIXED_PAIR=3,7 — no stub fallback; both pets must have Hub workers (peer_id).
# BATTLE_FIXED_PAIR=

# KeeperHub
KEEPERHUB_API_KEY=
KEEPERHUB_WALLET_INTEGRATION_ID=
ENS_HEARTBEAT_INTERVAL_MS=60000
# Publicly reachable Hub base URL for KeeperHub webhooks. Leave blank for the
# local Hub auto-delivery bridge; localhost URLs are treated as blank.
# For hosted demos, expose port 3001 with ngrok/cloudflared and set this to that URL.
HUB_BASE_URL=

# ENS (filled after tama.eth setup, namehash of "tama.eth")
TAMA_ETH_NODE_HASH=

# Contracts (filled after Phase 2 deploy)
TAMA_PET_ADDRESS=
PET_WALLET_FACTORY_ADDRESS=
BATTLE_ESCROW_ADDRESS=
SUBSCRIPTION_REGISTRY_ADDRESS=

# ENS contracts on Sepolia
ENS_REGISTRY=0x00000000000C2E074eC69A0dFb2997BA6C7d2e1e
ENS_NAME_WRAPPER=0x0635513f179D50A207757E05759CbD106d7dFcE8
ENS_PUBLIC_RESOLVER=0x8FADE66B79cC9f707aB26799354482EB93a5B7dD

# USDC on Sepolia (Circle test)
USDC_SEPOLIA=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
