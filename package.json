{
  "name": "eth-open-agents",
  "version": "0.1.0",
  "private": true,
  "description": "PetCity — persistent AI agent pets on Ethereum",
  "scripts": {
    "build:contracts": "cd contracts && forge build",
    "build:web": "cd apps/web && pnpm build",
    "build:hub": "cd apps/hub && pnpm tsc --noEmit",
    "dev:web": "cd apps/web && pnpm dev",
    "dev:hub": "cd apps/hub && pnpm tsx src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
